{
  "productName": "MusicLI",
  "version": "3.3.0",
  "identifier": "com.kirarineko.musicli",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1430",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "features": ["gui"]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MusicLI",
        "width": 950,
        "height": 650,
        "minWidth": 700,
        "minHeight": 400,
        "decorations": false,
        "center": true,
        "transparent": true,
        "shadow": false,
        "backgroundColor": "#0c0c0c"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libasound2"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3", "alsa-lib"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
